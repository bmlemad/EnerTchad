/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https://images.unsplash.com https://upload.wikimedia.org https://commons.wikimedia.org; connect-src 'self' https://images.unsplash.com https://upload.wikimedia.org https://commons.wikimedia.org; base-uri 'self'; form-action 'self'; frame-ancestors 'self'
/assets/*
  Cache-Control: public, max-age=31536000, immutable
